# Firebase Configuration
# Copy this file to .env and fill in your Firebase project credentials

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# App ID for Firestore (can be any unique identifier)
VITE_APP_ID=content-cadence-app

# API Base URL (optional - for backend proxy)
VITE_API_BASE_URL=/api

# Twitter / X API v2
# Get credentials from https://developer.twitter.com/
VITE_TWITTER_CLIENT_ID=your_twitter_client_id
VITE_TWITTER_CLIENT_SECRET=your_twitter_client_secret

# Facebook / Instagram Graph API
# Get credentials from https://developers.facebook.com/
VITE_FACEBOOK_CLIENT_ID=your_facebook_client_id
VITE_FACEBOOK_CLIENT_SECRET=your_facebook_client_secret

# Pinterest API
# Get credentials from https://developers.pinterest.com/
VITE_PINTEREST_CLIENT_ID=your_pinterest_client_id
VITE_PINTEREST_CLIENT_SECRET=your_pinterest_client_secret

# YouTube Data API
# Get credentials from https://console.cloud.google.com/
VITE_YOUTUBE_CLIENT_ID=your_youtube_client_id
VITE_YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# Snapchat API
# Get credentials from https://developers.snap.com/
VITE_SNAPCHAT_CLIENT_ID=your_snapchat_client_id
VITE_SNAPCHAT_CLIENT_SECRET=your_snapchat_client_secret

# Reddit API
# Get credentials from https://www.reddit.com/prefs/apps
VITE_REDDIT_CLIENT_ID=your_reddit_client_id
VITE_REDDIT_CLIENT_SECRET=your_reddit_client_secret